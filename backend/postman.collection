                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"slug\": \"cliente-b\",\n  \"name\": \"Cliente B\",\n  \"dbConnectionUrl\": \"postgresql://postgres.<project-ref>:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres\",\n  \"active\": true\n}"

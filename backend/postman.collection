        {
            "name": "Auth",
            "item": [
                {
                    "name": "Signup Email",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const json = pm.response.json();",
                                    "pm.collectionVariables.set('accessToken', json.accessToken || '');",
                                    "pm.collectionVariables.set('refreshToken', json.refreshToken || '');",
                                    "pm.collectionVariables.set('customerId', json.customerId || '');",
                                    "pm.collectionVariables.set('userId', json.user?.id || '');",
                                    "pm.collectionVariables.set('tenantId', json.user?.tenantId || json.tenantId || '');",
                                    "pm.collectionVariables.set('sessionId', json.sessionId || '');"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "x-tenant-slug",
                                "value": "{{tenantSlug}}"
                            },
                            {
                                "key": "x-guest-id",
                                "value": "{{guestId}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password123\"\n}"
                        },
                        "url": "{{baseUrl}}/auth/signup/email"
                    }
                },
                {
                    "name": "Login Unified Email",
                    "event": [

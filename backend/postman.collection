                {
                    "name": "Login OAuth Google",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "x-tenant-slug",
                                "value": "{{tenantSlug}}"
                            },
                            {
                                "key": "x-guest-id",
                                "value": "{{guestId}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"idToken\": \"<google-id-token>\"\n}"
                        },
                        "url": "{{baseUrl}}/auth/login/oauth/google"
                    }
                },
                {
                    "name": "Refresh Token",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "const json = pm.response.json();",
                                    "pm.collectionVariables.set('accessToken', json.accessToken || '');",
                                    "pm.collectionVariables.set('refreshToken', json.refreshToken || '');",
                                    "pm.collectionVariables.set('sessionId', json.sessionId || '');",
                                    "if (json.customerId) pm.collectionVariables.set('customerId', json.customerId);",
                                    "if (json.tenantId) pm.collectionVariables.set('tenantId', json.tenantId);"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "x-tenant-slug",
                                "value": "{{tenantSlug}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                        },
                        "url": "{{baseUrl}}/auth/refresh"
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "x-tenant-slug",
                                "value": "{{tenantSlug}}"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{accessToken}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                        },
                        "url": "{{baseUrl}}/auth/logout"
                    }
                },
